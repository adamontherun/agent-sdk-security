# Step 3 — inject a credential the agent never holds.
#
# Because the proxy now decrypts requests, it can also rewrite them. Here it
# adds an Authorization header to every request bound for an allowlisted host.
# The agent's own request carries no credential; the upstream API still
# receives one. This is the whole point of the proxy pattern: a secret the
# agent never sees is a secret it cannot leak, log, or be tricked into sending
# somewhere else.

acl allowed_domains dstdomain .anthropic.com .github.com .httpbin.org example.com mock-api
acl SSL_ports port 443
acl CONNECT method CONNECT
http_access deny CONNECT !SSL_ports

http_port 3128 ssl-bump \
  generate-host-certificates=on \
  dynamic_cert_mem_cache_size=4MB \
  tls-cert=/etc/squid/certs/squid-ca.pem \
  tls-key=/etc/squid/certs/squid-ca.key

sslcrtd_program /usr/lib/squid/security_file_certgen -s /var/lib/squid/ssl_db -M 4MB
sslcrtd_children 5

acl step1 at_step SslBump1
ssl_bump peek step1
ssl_bump bump allowed_domains
ssl_bump terminate all

http_access allow allowed_domains
http_access deny all

# The injection. In a real deployment the value would come from a secret store
# and never appear in the config file; it is inline here so the lab is
# self-contained. request_header_add only applies to the requests Squid can
# see, which is why it works on both the plain-HTTP mock and the bumped HTTPS
# traffic above, but would do nothing to a connection that was merely tunnelled.
request_header_add Authorization "Bearer sk-lab-INJECTED-BY-PROXY" allowed_domains

logfile_rotate 0
access_log stdio:/var/log/squid/access.log
coredump_dir /var/spool/squid
